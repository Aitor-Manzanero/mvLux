{
  "compilerOptions": {
    /* Estructura del Proyecto */
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "./src",            /* Descomentado: donde estará tu código .ts */
    "outDir": "./dist",           /* Descomentado: donde se generará el .js */
    
    /* Interoperabilidad y Seguridad */
    "strict": true,
    "esModuleInterop": true,      /* Vital para importar Express correctamente */
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Tipado mejorado (los tenías y son buenos) */
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "moduleDetection": "force",
    
    /* Generación de archivos para debugging */
    "sourceMap": true,
    "declaration": false 
  },
  "include": ["src/**/*"],         /* Indica a TS que solo mire la carpeta src */
  "exclude": ["node_modules", "**/*.test.ts"]
}